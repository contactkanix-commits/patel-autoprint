{
  "name": "patel-autoprint-backend",
  "version": "2.0.0",
  "private": true,
  "description": "Patel AutoPrint Backend API",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "npx prisma generate && npx prisma db push && node prisma/seed.js && node src/server.js",
    "build": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.8.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.6.0",
    "multer": "^1.4.5-lts.1",
    "pdf-lib": "^1.17.1",
    "pdf-to-printer": "^5.8.0",
    "pdfjs-dist": "^3.11.174",
    "sharp": "^0.33.2",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "prisma": "^5.8.1"
  }
}
